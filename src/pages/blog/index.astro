---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { blogPosts } from '../../data/blog-posts';

function formatFecha(iso: string) {
  const [y, m, d] = iso.split('-');
  const meses = ['ene','feb','mar','abr','may','jun','jul','ago','sep','oct','nov','dic'];
  return `${parseInt(d)} ${meses[parseInt(m) - 1]} ${y}`;
}

const sectores = [
  'Empresas Industriales',
  'Construcción',
  'Educativo y Recreativo',
  'Comercial y Oficinas',
];
---

<BaseLayout
  title="Blog de Higiene y Seguridad Laboral — SIGMETRÍA HyS"
  description="Artículos prácticos sobre normativa SRT, Decreto 351/79, 911/96, EPP y mediciones. Para empresas de CABA y GBA que quieren cumplir y proteger a su equipo."
>
  <section class="page-hero">
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <a href="/">Inicio</a><span>/</span>
      <span>Blog</span>
    </nav>
    <div class="page-hero-inner blog-hero-inner">
      <div class="blog-hero-left">
        <div class="page-hero-badge">Normativa · EPP · Mediciones · Gestión</div>
        <h1>BLOG DE<br><em>H&amp;S LABORAL</em></h1>
      </div>
      <p class="blog-hero-desc">Artículos prácticos escritos por profesionales. Sin tecnicismos innecesarios — lo que necesitás saber para cumplir y proteger a tu equipo.</p>
    </div>
  </section>

  <section class="content-section">
    <div class="content-inner">

      <!-- Buscador -->
      <div class="blog-toolbar">
        <div class="blog-search-wrap">
          <svg class="blog-search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input
            id="blog-search"
            type="search"
            placeholder="Buscar artículos..."
            autocomplete="off"
            spellcheck="false"
          />
        </div>
        <span class="blog-count" id="blog-count">{blogPosts.length} artículos</span>
      </div>

      <!-- Filtros por sector -->
      <div class="blog-filters" id="blog-filters">
        <button class="blog-filter active" data-sector="todos">Todos</button>
        {sectores.map(s => (
          <button class="blog-filter" data-sector={s}>{s}</button>
        ))}
      </div>

      <!-- Grid -->
      <div class="blog-grid" id="blog-grid">
        {blogPosts.map(post => (
          <article
            class="blog-card"
            data-sectores={post.sectores.join('|')}
            data-text={`${post.titulo} ${post.resumen} ${post.categoria} ${post.tags.join(' ')}`.toLowerCase()}
          >
            <div class="blog-card-meta">
              <span class="blog-cat">{post.categoria}</span>
              <span class="blog-sep">·</span>
              <span class="blog-fecha">{formatFecha(post.fecha)}</span>
              <span class="blog-sep">·</span>
              <span class="blog-tiempo">{post.tiempoLectura} lectura</span>
            </div>
            <h2 class="blog-card-title">
              <a href={`/blog/${post.slug}/`}>{post.titulo}</a>
            </h2>
            <p class="blog-card-resumen">{post.resumen}</p>
            <div class="blog-card-footer">
              <div class="blog-tags">
                {post.tags.slice(0, 3).map(tag => (
                  <span class="blog-tag">{tag}</span>
                ))}
              </div>
              <a href={`/blog/${post.slug}/`} class="blog-read-more">Leer →</a>
            </div>
          </article>
        ))}
      </div>

      <!-- Empty state -->
      <div class="blog-empty" id="blog-empty" style="display:none">
        <p>No hay artículos que coincidan con tu búsqueda.</p>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
/* ---- Hero two-column ---- */
.blog-hero-inner {
  max-width: 1100px !important;
  display: flex;
  align-items: center;
  gap: 60px;
}
.blog-hero-left { flex-shrink: 0; }
.blog-hero-desc {
  font-size: 15px;
  font-weight: 300;
  color: var(--gris-2);
  line-height: 1.8;
  max-width: 360px;
  margin: 0;
}
@media (max-width: 900px) {
  .blog-hero-inner { flex-direction: column; align-items: flex-start; gap: 14px; }
  .blog-hero-desc { max-width: 100%; }
}

/* ---- Toolbar ---- */
.blog-toolbar {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 16px;
  flex-wrap: wrap;
}
.blog-search-wrap {
  position: relative;
  flex: 1;
  min-width: 220px;
}
.blog-search-icon {
  position: absolute;
  left: 12px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--gris-3);
  pointer-events: none;
}
#blog-search {
  width: 100%;
  background: var(--blanco);
  border: 1px solid var(--borde);
  border-radius: 6px;
  padding: 10px 14px 10px 36px;
  font-family: 'Montserrat', sans-serif;
  font-size: .8rem;
  color: var(--gris-1);
  outline: none;
  transition: border-color .2s;
  box-sizing: border-box;
}
#blog-search::placeholder { color: var(--gris-3); }
#blog-search:focus { border-color: var(--verde); }
#blog-search::-webkit-search-cancel-button { cursor: pointer; }
.blog-count {
  font-family: 'Montserrat', sans-serif;
  font-size: .56rem;
  font-weight: 600;
  color: var(--gris-3);
  letter-spacing: .5px;
  white-space: nowrap;
  flex-shrink: 0;
}

/* ---- Filtros ---- */
.blog-filters {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 28px;
}
.blog-filter {
  font-family: 'Montserrat', sans-serif;
  font-size: .56rem;
  font-weight: 600;
  letter-spacing: .6px;
  text-transform: uppercase;
  color: var(--gris-2);
  background: var(--blanco);
  border: 1px solid var(--borde);
  border-radius: 4px;
  padding: 5px 12px;
  cursor: pointer;
  transition: all .18s;
  white-space: nowrap;
}
.blog-filter:hover {
  color: var(--verde);
  border-color: var(--verde-borde);
  background: var(--verde-light);
}
.blog-filter.active {
  color: var(--verde-dark);
  background: var(--verde-light);
  border-color: var(--verde);
}

/* ---- Grid ---- */
.blog-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 20px;
}
.blog-card {
  background: var(--blanco);
  border: 1px solid var(--borde);
  border-radius: 10px;
  padding: 24px 20px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  transition: all .25s;
  position: relative;
  overflow: hidden;
}
.blog-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: var(--verde);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform .3s;
}
.blog-card:hover {
  border-color: var(--verde-borde);
  transform: translateY(-3px);
  box-shadow: 0 12px 32px rgba(0,0,0,.08);
}
.blog-card:hover::before { transform: scaleX(1); }
.blog-card.hidden { display: none; }
.blog-card-meta {
  display: flex;
  align-items: center;
  gap: 7px;
  flex-wrap: wrap;
}
.blog-cat {
  font-family: 'Montserrat', sans-serif;
  font-size: .52rem;
  font-weight: 600;
  color: var(--verde-dark);
  background: var(--verde-light);
  border: 1px solid var(--verde-borde);
  padding: 3px 8px;
  border-radius: 3px;
  letter-spacing: .5px;
  text-transform: uppercase;
}
.blog-sep { color: var(--borde); font-size: .75rem; }
.blog-fecha, .blog-tiempo {
  font-family: 'Montserrat', sans-serif;
  font-size: .55rem;
  font-weight: 400;
  color: var(--gris-3);
}
.blog-card-title {
  font-family: 'Montserrat', sans-serif;
  font-size: 15px;
  font-weight: 700;
  line-height: 1.45;
  text-transform: none;
  letter-spacing: 0;
}
.blog-card-title a { color: var(--gris-1); text-decoration: none; transition: color .2s; }
.blog-card-title a:hover { color: var(--verde); }
.blog-card-resumen {
  font-size: 13px;
  font-weight: 300;
  color: var(--gris-2);
  line-height: 1.7;
  flex: 1;
}
.blog-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  flex-wrap: wrap;
  border-top: 1px solid var(--borde);
  padding-top: 12px;
}
.blog-tags { display: flex; gap: 6px; flex-wrap: wrap; }
.blog-tag {
  font-family: 'Montserrat', sans-serif;
  font-size: .48rem;
  font-weight: 600;
  color: var(--gris-3);
  background: var(--gris-bg);
  border: 1px solid var(--borde);
  padding: 2px 7px;
  border-radius: 3px;
  letter-spacing: .4px;
  text-transform: uppercase;
}
.blog-read-more {
  font-family: 'Montserrat', sans-serif;
  font-size: .58rem;
  font-weight: 700;
  color: var(--verde);
  text-decoration: none;
  letter-spacing: .8px;
  text-transform: uppercase;
  transition: color .2s;
  white-space: nowrap;
}
.blog-read-more:hover { color: var(--verde-dark); }

/* ---- Empty state ---- */
.blog-empty {
  text-align: center;
  padding: 60px 20px;
  color: var(--gris-3);
  font-size: 14px;
  font-weight: 300;
}

@media (max-width: 600px) {
  .blog-grid { grid-template-columns: 1fr; }
  .blog-toolbar { flex-direction: column; align-items: stretch; }
  .blog-count { text-align: right; }
}
</style>

<script>
const cards   = Array.from(document.querySelectorAll<HTMLElement>('#blog-grid .blog-card'));
const filters = Array.from(document.querySelectorAll<HTMLButtonElement>('#blog-filters .blog-filter'));
const search  = document.getElementById('blog-search') as HTMLInputElement;
const count   = document.getElementById('blog-count') as HTMLElement;
const empty   = document.getElementById('blog-empty') as HTMLElement;

let activeSector = 'todos';
let searchVal    = '';

function update() {
  let visible = 0;
  cards.forEach(card => {
    const sectores = (card.dataset.sectores ?? '').split('|');
    const sectorMatch = activeSector === 'todos' || sectores.includes(activeSector);
    const textMatch   = !searchVal || (card.dataset.text ?? '').includes(searchVal);
    const show = sectorMatch && textMatch;
    card.classList.toggle('hidden', !show);
    if (show) visible++;
  });
  count.textContent = `${visible} artículo${visible !== 1 ? 's' : ''}`;
  empty.style.display = visible === 0 ? 'block' : 'none';
}

filters.forEach(btn => {
  btn.addEventListener('click', () => {
    filters.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    activeSector = btn.dataset.sector ?? 'todos';
    update();
  });
});

search.addEventListener('input', () => {
  searchVal = search.value.toLowerCase().trim();
  update();
});

// Leer parámetro ?sector= de la URL para pre-filtrar desde el nav
const urlSector = new URLSearchParams(window.location.search).get('sector');
if (urlSector) {
  const btn = filters.find(b => b.dataset.sector === urlSector);
  if (btn) {
    filters.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    activeSector = urlSector;
    update();
  }
}
</script>
