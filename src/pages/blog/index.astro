---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { blogPosts } from '../../data/blog-posts';

function formatFecha(iso: string) {
  const [y, m, d] = iso.split('-');
  const meses = ['ene','feb','mar','abr','may','jun','jul','ago','sep','oct','nov','dic'];
  return `${parseInt(d)} ${meses[parseInt(m) - 1]} ${y}`;
}
---

<BaseLayout
  title="Blog de Higiene y Seguridad Laboral — Privisor HyS"
  description="Artículos prácticos sobre normativa SRT, Decreto 351/79, 911/96, EPP y mediciones. Para empresas de CABA y GBA que quieren cumplir y proteger a su equipo."
>
  <section class="page-hero">
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <a href="/">Inicio</a><span>/</span>
      <span>Blog</span>
    </nav>
    <div class="page-hero-inner">
      <div class="page-hero-badge">Normativa · EPP · Mediciones · Gestión</div>
      <h1>BLOG DE<br><em>H&amp;S LABORAL</em></h1>
      <p>Artículos prácticos escritos por profesionales. Sin tecnicismos innecesarios — lo que necesitás saber para cumplir y proteger a tu equipo.</p>
    </div>
  </section>

  <section class="content-section">
    <div class="content-inner">
      <div class="blog-grid">
        {blogPosts.map(post => (
          <article class="blog-card">
            <div class="blog-card-meta">
              <span class="blog-cat">{post.categoria}</span>
              <span class="blog-sep">·</span>
              <span class="blog-fecha">{formatFecha(post.fecha)}</span>
              <span class="blog-sep">·</span>
              <span class="blog-tiempo">{post.tiempoLectura} lectura</span>
            </div>
            <h2 class="blog-card-title">
              <a href={`/blog/${post.slug}/`}>{post.titulo}</a>
            </h2>
            <p class="blog-card-resumen">{post.resumen}</p>
            <div class="blog-card-footer">
              <div class="blog-tags">
                {post.tags.slice(0, 3).map(tag => (
                  <span class="blog-tag">{tag}</span>
                ))}
              </div>
              <a href={`/blog/${post.slug}/`} class="blog-read-more">Leer →</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.blog-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 20px;
}
.blog-card {
  background: var(--azul-navy);
  border: 1px solid rgba(201,162,39,0.22);
  border-radius: 10px;
  padding: 24px 20px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  transition: all .25s;
}
.blog-card:hover {
  border-color: rgba(100,210,255,0.3);
  background: #001f5a;
  transform: translateY(-3px);
  box-shadow: 0 12px 36px rgba(0,0,0,0.35);
}
.blog-card-meta {
  display: flex;
  align-items: center;
  gap: 7px;
  flex-wrap: wrap;
}
.blog-cat {
  font-family: 'JetBrains Mono', monospace;
  font-size: .54rem;
  color: var(--dorado);
  background: rgba(201,162,39,0.09);
  border: 1px solid rgba(201,162,39,0.2);
  padding: 3px 8px;
  border-radius: 3px;
  letter-spacing: .5px;
  text-transform: uppercase;
}
.blog-sep { color: rgba(255,255,255,.2); font-size: .75rem; }
.blog-fecha, .blog-tiempo {
  font-family: 'JetBrains Mono', monospace;
  font-size: .55rem;
  color: rgba(255,255,255,.3);
}
.blog-card-title {
  font-family: 'Montserrat', sans-serif;
  font-size: 15px;
  font-weight: 700;
  line-height: 1.45;
  text-transform: none;
  letter-spacing: 0;
}
.blog-card-title a { color: #fff; text-decoration: none; transition: color .2s; }
.blog-card-title a:hover { color: var(--celeste); }
.blog-card-resumen {
  font-size: 13px;
  font-weight: 300;
  color: var(--texto-med);
  line-height: 1.7;
  flex: 1;
}
.blog-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  flex-wrap: wrap;
  border-top: 1px solid rgba(255,255,255,.05);
  padding-top: 12px;
}
.blog-tags { display: flex; gap: 6px; flex-wrap: wrap; }
.blog-tag {
  font-family: 'JetBrains Mono', monospace;
  font-size: .48rem;
  color: rgba(100,210,255,.55);
  background: rgba(100,210,255,0.05);
  border: 1px solid rgba(100,210,255,0.1);
  padding: 2px 7px;
  border-radius: 3px;
  letter-spacing: .4px;
}
.blog-read-more {
  font-family: 'JetBrains Mono', monospace;
  font-size: .6rem;
  color: var(--celeste);
  text-decoration: none;
  letter-spacing: .8px;
  transition: color .2s;
  white-space: nowrap;
}
.blog-read-more:hover { color: #fff; }
@media (max-width: 600px) { .blog-grid { grid-template-columns: 1fr; } }
</style>
