---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const servicios = [
  { icon: '🚨', title: 'Plan de emergencia y evacuación', desc: 'Identificación de riesgos, roles, procedimientos, planos actualizados y sistema de comunicación de alertas para el establecimiento.', res: 'Ley 5920 CABA' },
  { icon: '🗺️', title: 'Planos de evacuación', desc: 'Diseño por planta, señalización de salidas, extintores y puntos de encuentro para alumnos y personal.', res: 'Ley 5920' },
  { icon: '🧯', title: 'Formación de brigadas', desc: 'Designación y capacitación de brigadistas y jefes de evacuación. Roles definidos ante diferentes tipos de emergencia.', res: 'Capacitación certificada' },
  { icon: '🏃', title: 'Simulacros de evacuación', desc: 'Coordinación y conducción con registro fotográfico, informe técnico y certificación. Cumplimiento total de la Ley 5920.', res: 'Registro obligatorio' },
];
---

<BaseLayout
  title="Plan de Emergencia para Colegios y Clubes | Ley 5920 | Privisor HyS"
  description="Plan de emergencia, planos de evacuación, formación de brigadas y simulacros para colegios y establecimientos recreativos en CABA. Ley 5920 de Autoprotección."
>
  <section class="page-hero">
    <div class="page-hero-inner">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="/">Inicio</a><span>/</span>
        <a href="/servicios/">Servicios</a><span>/</span>
        <a href="/servicios/educativo-recreativo/">Educativo & Recreativo</a><span>/</span>
        <span>Planes de emergencia</span>
      </nav>
      <div class="page-hero-badge">Ley 5920 · CABA</div>
      <h1>PLANES DE<br><em>EMERGENCIA</em></h1>
      <p>Cumplimiento de la Ley de Autoprotección 5920 para CABA. Obligatorio para establecimientos educativos y recreativos. Gestionamos todo el proceso de principio a fin.</p>
    </div>
  </section>
  <section class="content-section">
    <div class="content-inner">
      <div class="cards-grid">
        {servicios.map(s => (
          <article class="card">
            <div class="card-icon" aria-hidden="true">{s.icon}</div>
            <div class="card-badge">{s.res}</div>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </article>
        ))}
      </div>
      <div class="cta-banner">
        <h2>¿TU COLEGIO TIENE EL <em style="font-style:normal;background:linear-gradient(90deg,#64d2ff,#4dc8f5);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">PLAN ACTUALIZADO</em>?</h2>
        <p>La Ley 5920 exige actualización anual del Plan de Autoprotección. Consultanos y lo regularizamos rápido.</p>
        <div class="cta-actions">
          <a href="https://wa.me/5491133572984" class="btn-primary" target="_blank" rel="noopener">💬 Consultanos</a>
          <a href="/contacto/" class="btn-outline">Formulario</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
