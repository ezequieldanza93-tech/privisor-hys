---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const mediciones = [
  { icon: '💡', title: 'Iluminación', desc: 'Aulas, laboratorios, pasillos, gimnasios y espacios comunes.', res: 'Res. SRT 84 / 85' },
  { icon: '🔊', title: 'Ruido', desc: 'Talleres, espacios de recreación y zonas con equipamiento ruidoso.', res: 'Res. SRT 85 / 960' },
  { icon: '⚡', title: 'Puesta a tierra y disyuntores', desc: 'Laboratorios de informática, equipamiento audiovisual y cocinas.', res: 'AEA / IRAM' },
  { icon: '🌡️', title: 'Estrés Térmico', desc: 'Confort térmico en aulas, cocinas de buffet y espacios deportivos cubiertos.', res: 'Res. SRT 30/23' },
  { icon: '🧍', title: 'Ergonomía', desc: 'Puestos docentes y administrativos. Análisis de mobiliario escolar.', res: 'Protocolo 886' },
];
---
<BaseLayout
  title="Mediciones HyS en Establecimientos Educativos | SIGMETRÍA HyS"
  description="Mediciones de iluminación, ruido, estrés térmico y ergonomía en colegios y centros recreativos de CABA y GBA."
>
  <section class="page-hero">
    <div class="page-hero-inner">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="/">Inicio</a><span>/</span><a href="/servicios/">Servicios</a><span>/</span>
        <a href="/servicios/educativo-recreativo/">Educativo & Recreativo</a><span>/</span>
        <span>Mediciones</span>
      </nav>
      <div class="page-hero-badge">Resoluciones SRT</div>
      <h1>MEDICIONES<br><em>EN EDIFICIOS EDUCATIVOS</em></h1>
      <p>Mediciones técnicas exigidas en establecimientos educativos y recreativos. Instrumentos calibrados y protocolos firmados por profesional matriculado.</p>
    </div>
  </section>
  <section class="content-section">
    <div class="content-inner">
      <div class="cards-grid">
        {mediciones.map(m => (
          <article class="card">
            <div class="card-icon">{m.icon}</div>
            <h3>{m.title}</h3><p>{m.desc}</p>
            <div class="card-res">{m.res}</div>
          </article>
        ))}
      </div>
      <div class="cta-banner">
        <h2>SOLICITÁ TUS <em style="font-style:normal;background:linear-gradient(90deg,#64d2ff,#4dc8f5);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">MEDICIONES</em></h2>
        <p>Coordinamos la visita en el horario que menos interrumpa la actividad del establecimiento.</p>
        <div class="cta-actions">
          <a href="https://wa.me/5491123496789" class="btn-primary" target="_blank" rel="noopener">💬 Pedir cotización</a>
          <a href="/contacto/" class="btn-outline">Formulario</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
