---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const mediciones = [
  { icon: '💡', title: 'Iluminación', desc: 'Cajas, depósitos, salón de ventas, cocinas y oficinas internas.', res: 'Res. SRT 84 / 85' },
  { icon: '🔊', title: 'Ruido', desc: 'Música ambiental, maquinaria de frío, extractores y equipos de procesamiento.', res: 'Res. SRT 85 / 960' },
  { icon: '⚡', title: 'Puesta a tierra y disyuntores', desc: 'Cámaras de frío, cocina industrial, sistemas de cómputo. Tiempo de respuesta de disyuntores.', res: 'AEA / IRAM' },
  { icon: '🌡️', title: 'Estrés Térmico', desc: 'Cocinas, depósitos sin climatización y cámaras de frío.', res: 'Res. SRT 30/23' },
  { icon: '🧍', title: 'Ergonomía', desc: 'Puestos de caja, administrativos y repositores. Manejo manual de cargas.', res: 'Protocolo 886' },
];
---
<BaseLayout
  title="Mediciones HyS para Locales Comerciales | SIGMETRÍA HyS"
  description="Mediciones de iluminación, ruido, estrés térmico y ergonomía para locales comerciales, restaurantes y oficinas en CABA y GBA."
>
  <section class="page-hero">
    <div class="page-hero-inner">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="/">Inicio</a><span>/</span><a href="/servicios/">Servicios</a><span>/</span>
        <a href="/servicios/locales-comerciales/">Locales Comerciales</a><span>/</span>
        <span>Mediciones</span>
      </nav>
      <div class="page-hero-badge">Resoluciones SRT · AEA</div>
      <h1>MEDICIONES<br><em>EN LOCALES COMERCIALES</em></h1>
      <p>Mediciones técnicas aplicables a locales comerciales, oficinas y espacios de atención al público. Instrumentos calibrados, protocolos firmados.</p>
    </div>
  </section>
  <section class="content-section">
    <div class="content-inner">
      <div class="cards-grid">
        {mediciones.map(m => (
          <article class="card">
            <div class="card-icon">{m.icon}</div>
            <h3>{m.title}</h3><p>{m.desc}</p>
            <div class="card-res">{m.res}</div>
          </article>
        ))}
      </div>
      <div class="cta-banner">
        <h2>MEDICIONES PARA <em style="font-style:normal;background:linear-gradient(90deg,#64d2ff,#4dc8f5);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">TU LOCAL</em></h2>
        <p>Coordinamos la visita en el horario que menos afecte tu operación. Resultados en 48 horas.</p>
        <div class="cta-actions">
          <a href="https://wa.me/5491123496789" class="btn-primary" target="_blank" rel="noopener">💬 Pedir cotización</a>
          <a href="/contacto/" class="btn-outline">Formulario</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
