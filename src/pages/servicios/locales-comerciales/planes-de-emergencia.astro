---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const servicios = [
  { icon: '🚨', title: 'Plan de Emergencia', desc: 'Incendio, robo, emergencia médica. Procedimientos claros para personal de atención al público.', res: 'Ley 5920 CABA' },
  { icon: '🗺️', title: 'Planos de Evacuación', desc: 'Señalización de salidas, extintores y puntos de encuentro para clientes y personal.', res: 'Normativa vigente' },
  { icon: '🏃', title: 'Simulacros de Evacuación', desc: 'Organización y conducción con registro fotográfico y certificación. Cumplimiento Ley 5920.', res: 'Certificación incluida' },
];
---
<BaseLayout
  title="Plan de Emergencia para Locales Comerciales | Ley 5920 | SIGMETRÍA HyS"
  description="Plan de emergencia, planos de evacuación y simulacros para locales comerciales en CABA. Ley 5920 de Autoprotección."
>
  <section class="page-hero">
    <div class="page-hero-inner">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="/">Inicio</a><span>/</span><a href="/servicios/">Servicios</a><span>/</span>
        <a href="/servicios/locales-comerciales/">Locales Comerciales</a><span>/</span>
        <span>Planes de emergencia</span>
      </nav>
      <div class="page-hero-badge">Ley 5920 · CABA</div>
      <h1>PLANES DE EMERGENCIA<br><em>LOCALES COMERCIALES</em></h1>
      <p>Plan de emergencia y cumplimiento de Ley 5920 para locales comerciales en CABA. Obligatorio para establecimientos con atención al público.</p>
    </div>
  </section>
  <section class="content-section">
    <div class="content-inner">
      <div class="cards-grid">
        {servicios.map(s => (
          <article class="card">
            <div class="card-icon">{s.icon}</div>
            <div class="card-badge">{s.res}</div>
            <h3>{s.title}</h3><p>{s.desc}</p>
          </article>
        ))}
      </div>
      <div class="cta-banner">
        <h2>¿TU LOCAL TIENE EL <em style="font-style:normal;background:linear-gradient(90deg,#64d2ff,#4dc8f5);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">PLAN AL DÍA</em>?</h2>
        <p>La Ley 5920 es obligatoria para locales en CABA. Regularizate rápido y sin complicaciones.</p>
        <div class="cta-actions">
          <a href="https://wa.me/5491123496789" class="btn-primary" target="_blank" rel="noopener">💬 Consultanos</a>
          <a href="/contacto/" class="btn-outline">Formulario</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
