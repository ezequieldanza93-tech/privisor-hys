---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Higiene y Seguridad en Obras de Construcción",
  "description": "Servicios de Higiene y Seguridad para la industria de la construcción en CABA y GBA. Decreto 911/96, seguridad en obra, legajo técnico y gestión ART.",
  "provider": { "@type": "ProfessionalService", "name": "SIGMETRÍA HyS", "url": "https://sigmetriahys.com" },
  "areaServed": ["Ciudad Autónoma de Buenos Aires", "Gran Buenos Aires"]
};

const subcategorias = [
  { href: '/servicios/construccion/seguridad-en-obra/', icon: '👷', title: 'Seguridad en obra', desc: 'Programa de seguridad, visitas semanales de técnico y legajo técnico de seguridad completo.' },
  { href: '/servicios/construccion/mediciones/', icon: '📐', title: 'Mediciones en obra', desc: 'Iluminación, ruido, vibraciones, puesta a tierra y contaminantes según normativa vigente.' },
  { href: '/servicios/construccion/gestion-normativa/', icon: '📋', title: 'Gestión normativa', desc: 'RAR, RGRL, plan antisiniestral, capacitaciones y presentaciones ante ART para constructoras.' },
];
---

<BaseLayout
  title="Higiene y Seguridad en Construcción | Decreto 911/96 | SIGMETRÍA HyS"
  description="Servicios de Higiene y Seguridad para empresas constructoras en CABA y GBA. Decreto 911/96, programa de seguridad, visitas semanales y legajo técnico."
  schema={schema}
>
  <section class="page-hero">
    <div class="page-hero-inner">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="/">Inicio</a><span>/</span>
        <a href="/servicios/">Servicios</a><span>/</span>
        <span>Construcción</span>
      </nav>
      <div class="page-hero-badge">Decreto 911/96 · SRT</div>
      <h1>HIGIENE Y SEGURIDAD<br><em>EN CONSTRUCCIÓN</em></h1>
      <p>Obras civiles, constructoras e infraestructura. Cumplimiento total del Decreto 911/96. Técnico presente en obra con visitas semanales y legajo completo.</p>
    </div>
  </section>

  <section class="content-section">
    <div class="content-inner">
      <div class="subcats-grid">
        {subcategorias.map(s => (
          <a href={s.href} class="subcat-card">
            <span class="subcat-icon" aria-hidden="true">{s.icon}</span>
            <h2 class="subcat-title">{s.title}</h2>
            <p class="subcat-desc">{s.desc}</p>
            <span class="subcat-cta">Ver detalle →</span>
          </a>
        ))}
      </div>
      <div class="cta-banner">
        <h2>¿TENÉS UNA <em style="font-style:normal;background:linear-gradient(90deg,#64d2ff,#4dc8f5);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">OBRA EN MARCHA</em>?</h2>
        <p>Contactanos ahora. Podemos incorporarnos a tu obra de forma inmediata con toda la documentación en regla.</p>
        <div class="cta-actions">
          <a href="https://wa.me/5491123496789" class="btn-primary" target="_blank" rel="noopener">💬 Consulta urgente</a>
          <a href="/contacto/" class="btn-outline">Formulario de contacto</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.subcats-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; margin-bottom: 60px; }
.subcat-card { background:#001848;border:2px solid var(--verde-borde);border-radius:12px;padding:32px 26px;display:flex;flex-direction:column;text-decoration:none;transition:all .3s cubic-bezier(.34,1.3,.64,1);position:relative;overflow:hidden; }
.subcat-card::before { content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,#64d2ff,#4dc8f5);transform:scaleX(0);transform-origin:left;transition:transform .35s; }
.subcat-card:hover { background:#002060;border-color:var(--verde);transform:translateY(-5px);box-shadow:0 20px 48px rgba(0,0,0,0.45); }
.subcat-card:hover::before { transform:scaleX(1); }
.subcat-icon  { font-size:2.4rem;margin-bottom:16px; }
.subcat-title { font-family:'Montserrat',sans-serif;font-size:1.5rem;letter-spacing:2px;color:#fff;margin-bottom:10px; }
.subcat-desc  { font-size:13px;font-weight:300;color:rgba(255,255,255,.45);line-height:1.7;flex:1;margin-bottom:20px; }
.subcat-cta   { font-family:'Montserrat',sans-serif;font-size:.6rem;color:#64d2ff;letter-spacing:1px;border-top:1px solid var(--verde-light);padding-top:14px; }
@media(max-width:800px){ .subcats-grid{grid-template-columns:1fr;} }
</style>
