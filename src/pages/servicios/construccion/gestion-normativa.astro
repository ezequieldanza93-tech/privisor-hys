---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const items = [
  { num: '01', title: 'Presentaciones en ART — RAR y RGRL', desc: 'Relevamiento de agentes de riesgo para empresas constructoras. Gestión completa ante la Aseguradora.' },
  { num: '02', title: 'Plan de Capacitación en Obra', desc: 'Programa de capacitación: inducción, EPP, riesgos específicos de la obra y procedimientos de emergencia.' },
  { num: '03', title: 'Plan Antisiniestral', desc: 'Plan antisiniestral anual exigido por la ART para empresas constructoras. Objetivos e indicadores.' },
  { num: '04', title: 'Plan de Emergencia en Obra', desc: 'Plan de emergencia, evacuación, primeros auxilios y organización de brigadas para obras en CABA.' },
  { num: '05', title: 'Simulacros en Obra', desc: 'Organización y conducción con registro fotográfico, informe técnico y certificación.' },
];
---

<BaseLayout
  title="Gestión Normativa para Empresas Constructoras | SIGMETRÍA HyS"
  description="Gestión ante SRT y ART para constructoras: RAR, RGRL, plan antisiniestral y plan de emergencia. Decreto 911/96. CABA y GBA."
>
  <section class="page-hero">
    <div class="page-hero-inner">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="/">Inicio</a><span>/</span>
        <a href="/servicios/">Servicios</a><span>/</span>
        <a href="/servicios/construccion/">Construcción</a><span>/</span>
        <span>Gestión normativa</span>
      </nav>
      <div class="page-hero-badge">Decreto 911/96 · SRT · ART</div>
      <h1>GESTIÓN NORMATIVA<br><em>CONSTRUCCIÓN</em></h1>
      <p>Documentación y presentaciones ante SRT y ART para empresas del sector de la construcción. Todo en regla, sin demoras.</p>
    </div>
  </section>
  <section class="content-section">
    <div class="content-inner">
      <div class="items-list">
        {items.map(it => (
          <div class="item">
            <span class="item-num">{it.num}</span>
            <div><h3>{it.title}</h3><p>{it.desc}</p></div>
          </div>
        ))}
      </div>
      <div class="cta-banner">
        <h2>¿NECESITÁS <em style="font-style:normal;background:linear-gradient(90deg,#64d2ff,#4dc8f5);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">REGULARIZARTE</em>?</h2>
        <p>Asumimos la gestión normativa completa de tu empresa constructora. Sin sorpresas, sin multas.</p>
        <div class="cta-actions">
          <a href="https://wa.me/5491123496789" class="btn-primary" target="_blank" rel="noopener">💬 Consultanos</a>
          <a href="/contacto/" class="btn-outline">Formulario</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
