---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { servicios } from '../../data/servicios-data';
import type { ServicioIndividual } from '../../data/servicios-data';

export function getStaticPaths() {
  return servicios.map((s) => ({
    params: { slug: s.slug },
    props: { servicio: s },
  }));
}

interface Props { servicio: ServicioIndividual; }
const { servicio: s } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: s.titulo,
  description: s.metaDescription,
  provider: {
    '@type': 'ProfessionalService',
    name: 'Privisor HyS',
    telephone: '+5491133572984',
    areaServed: ['CABA', 'Gran Buenos Aires'],
  },
  serviceType: 'Higiene y Seguridad Laboral',
};

const normativaSearchUrl = `https://www.argentina.gob.ar/normativa/nacional?search=${encodeURIComponent(s.normativa.codigo.split('/')[0].trim())}`;
---

<BaseLayout
  title={`${s.titulo} — Privisor HyS`}
  description={s.metaDescription}
  schema={schema}
>
  <section class="page-hero">
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <a href="/">Inicio</a><span>/</span>
      <a href={s.sector.href}>{s.sector.label}</a><span>/</span>
      <a href={s.categoria.href}>{s.categoria.label}</a><span>/</span>
      <span>{s.titulo}</span>
    </nav>
    <div class="page-hero-inner">
      <div class="page-hero-badge">{s.badge}</div>
      <h1>{s.heroTitle.split('\n').map((line, i) => i === 1 ? <><em>{line}</em></> : line).reduce<(string | any)[]>((acc, part, i) => i === 0 ? [part] : [...acc, <br/>, part], [])}</h1>
      <p>{s.heroBajada}</p>
    </div>
  </section>

  <section class="content-section">
    <div class="content-inner">

      <!-- Bloque de normativa -->
      <div class="normativa-block">
        <div class="normativa-header">
          <span class="normativa-chip">{s.normativa.codigo}</span>
          <h2 class="normativa-title">{s.normativa.nombre}</h2>
        </div>
        <p class="normativa-resumen">{s.normativa.resumen}</p>
        <div class="normativa-footer">
          <div class="normativa-oblig">
            <span class="oblig-label">¿Quién debe cumplirla?</span>
            <p>{s.normativa.obligatoriedad}</p>
          </div>
          <a
            href={normativaSearchUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-outline normativa-link"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            Leer {s.normativa.codigo} en InfoLEG
          </a>
        </div>
      </div>

      <!-- ¿Qué medimos? -->
      <div class="section-block">
        <div class="kicker kicker--left">Lo que evaluamos</div>
        <h2 class="section-title">¿QUÉ <em>MEDIMOS</em>?</h2>
        <div class="cards-grid" style="margin-top:20px">
          {s.queMedimos.map((item, i) => (
            <div class="card">
              <div class="card-badge">Punto {String(i + 1).padStart(2, '0')}</div>
              <h3>{item.titulo}</h3>
              <p>{item.descripcion}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- ¿Qué incluye el servicio? -->
      <div class="section-block">
        <div class="kicker kicker--left">El servicio</div>
        <h2 class="section-title">¿QUÉ <em>INCLUYE</em>?</h2>
        <div class="items-list" style="margin-top:20px">
          {s.incluye.map((item, i) => (
            <div class="item">
              <span class="item-num">{String(i + 1).padStart(2, '0')}</span>
              <div>
                <p>{item}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="cta-banner">
        <div class="kicker">¿Necesitás este servicio?</div>
        <h2>PEDÍ TU <em>COTIZACIÓN</em></h2>
        <p>Te respondemos en menos de 24 horas hábiles con una propuesta personalizada para tu empresa.</p>
        <div class="cta-actions">
          <a href={`https://wa.me/5491133572984?text=Hola%2C%20necesito%20información%20sobre%20${encodeURIComponent(s.titulo)}`} class="btn-primary" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Consultar por WhatsApp
          </a>
          <a href="/contacto/" class="btn-outline">Formulario de contacto</a>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
/* ---- Normativa block ---- */
.normativa-block {
  background: linear-gradient(135deg, rgba(0,24,72,0.9), rgba(0,32,96,0.7));
  border: 1px solid rgba(201,162,39,0.3);
  border-left: 3px solid var(--dorado);
  border-radius: 10px;
  padding: 28px 24px;
  margin-bottom: 48px;
}
.normativa-header {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  flex-wrap: wrap;
  margin-bottom: 16px;
}
.normativa-chip {
  font-family: 'JetBrains Mono', monospace;
  font-size: .58rem;
  color: var(--dorado);
  background: rgba(201,162,39,0.1);
  border: 1px solid rgba(201,162,39,0.35);
  padding: 4px 10px;
  border-radius: 3px;
  letter-spacing: .8px;
  white-space: nowrap;
  flex-shrink: 0;
  margin-top: 2px;
}
.normativa-title {
  font-family: 'Montserrat', sans-serif;
  font-size: 14px;
  font-weight: 700;
  color: rgba(255,255,255,.85);
  text-transform: uppercase;
  letter-spacing: .5px;
  line-height: 1.4;
}
.normativa-resumen {
  font-size: 14px;
  font-weight: 300;
  color: rgba(255,255,255,.6);
  line-height: 1.8;
  margin-bottom: 20px;
}
.normativa-footer {
  display: flex;
  align-items: flex-start;
  gap: 20px;
  flex-wrap: wrap;
  justify-content: space-between;
}
.normativa-oblig {
  flex: 1;
  min-width: 240px;
}
.oblig-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: .55rem;
  color: var(--celeste);
  letter-spacing: 1.5px;
  text-transform: uppercase;
  display: block;
  margin-bottom: 6px;
}
.normativa-oblig p {
  font-size: 13px;
  font-weight: 300;
  color: rgba(255,255,255,.5);
  line-height: 1.65;
}
.normativa-link {
  flex-shrink: 0;
  font-size: .72rem;
  padding: 8px 16px;
  align-self: flex-end;
}

/* ---- Sección títulos ---- */
.section-block { margin-bottom: 48px; }
.section-title {
  font-family: 'Bebas Neue', cursive;
  font-size: clamp(28px, 4vw, 44px);
  letter-spacing: 2px;
  color: #fff;
  line-height: .95;
}
.section-title em {
  font-style: normal;
  background: linear-gradient(90deg, var(--celeste), var(--acento));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

@media (max-width: 640px) {
  .normativa-footer { flex-direction: column; }
  .normativa-link { width: 100%; justify-content: center; }
}
</style>
