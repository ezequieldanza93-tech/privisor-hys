---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { servicios } from '../../data/servicios-data';
import type { ServicioIndividual } from '../../data/servicios-data';

export function getStaticPaths() {
  return servicios.map((s) => ({
    params: { slug: s.slug },
    props: { servicio: s },
  }));
}

interface Props { servicio: ServicioIndividual; }
const { servicio: s } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: s.titulo,
  description: s.metaDescription,
  provider: {
    '@type': 'ProfessionalService',
    name: 'SIGMETRÍA HyS',
    telephone: '+5491123496789',
    areaServed: ['CABA', 'Gran Buenos Aires'],
  },
  serviceType: 'Higiene y Seguridad Laboral',
};

const normativaSearchUrl = s.normativa.url ?? `https://www.argentina.gob.ar/normativa/nacional?search=${encodeURIComponent(s.normativa.codigo.split('/')[0].trim())}`;
---

<BaseLayout
  title={`${s.titulo} — SIGMETRÍA HyS`}
  description={s.metaDescription}
  schema={schema}
>
  <section class="page-hero">
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <a href="/">Inicio</a><span>/</span>
      <a href={s.sector.href}>{s.sector.label}</a><span>/</span>
      <a href={s.categoria.href}>{s.categoria.label}</a><span>/</span>
      <span>{s.titulo}</span>
    </nav>
    <div class="page-hero-inner">
      <div class="page-hero-badge">{s.badge}</div>
      <h1 set:html={s.heroTitle.split('\n').map((line, i) => i === 1 ? `<em>${line}</em>` : line).join('<br/>')} />
      <p>{s.heroBajada}</p>
    </div>
  </section>

  <section class="content-section">
    <div class="content-inner">

      <!-- Bloque de normativa -->
      <div class="normativa-block">
        <div class="normativa-header">
          <span class="normativa-chip">{s.normativa.codigo}</span>
          <h2 class="normativa-title">{s.normativa.nombre}</h2>
        </div>
        <p class="normativa-resumen">{s.normativa.resumen}</p>
        <div class="normativa-footer">
          <div class="normativa-oblig">
            <span class="oblig-label">¿Quién debe cumplirla?</span>
            <p>{s.normativa.obligatoriedad}</p>
          </div>
          <a
            href={normativaSearchUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-outline normativa-link"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            Leer {s.normativa.codigo} en InfoLEG
          </a>
        </div>
      </div>

      <!-- ¿Qué medimos? -->
      <div class="section-block">
        <div class="kicker kicker--left">Lo que evaluamos</div>
        <h2 class="section-title">¿QUÉ <em>MEDIMOS</em>?</h2>
        <div class="cards-grid" style="margin-top:20px">
          {s.queMedimos.map((item, i) => (
            <div class="card">
              <div class="card-badge">Punto {String(i + 1).padStart(2, '0')}</div>
              <h3>{item.titulo}</h3>
              <p>{item.descripcion}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- ¿Qué incluye el servicio? -->
      <div class="section-block">
        <div class="kicker kicker--left">El servicio</div>
        <h2 class="section-title">¿QUÉ <em>INCLUYE</em>?</h2>
        <div class="items-list" style="margin-top:20px">
          {s.incluye.map((item, i) => (
            <div class="item">
              <span class="item-num">{String(i + 1).padStart(2, '0')}</span>
              <div>
                <p>{item}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="cta-banner">
        <div class="kicker">¿Necesitás este servicio?</div>
        <h2>PEDÍ TU <em>COTIZACIÓN</em></h2>
        <p>Te respondemos en menos de 24 horas hábiles con una propuesta personalizada para tu empresa.</p>
        <div class="cta-actions">
          <a href={`https://wa.me/5491123496789?text=Hola%2C%20necesito%20información%20sobre%20${encodeURIComponent(s.titulo)}`} class="btn-primary" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Consultar por WhatsApp
          </a>
          <a href="/contacto/" class="btn-outline">Formulario de contacto</a>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

