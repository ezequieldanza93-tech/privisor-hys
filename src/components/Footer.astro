---
const servicios = [
  { href: '/servicios/empresas-industriales/', label: 'Empresas Industriales' },
  { href: '/servicios/construccion/',          label: 'Construcción' },
  { href: '/servicios/educativo-recreativo/',  label: 'Educativo & Recreativo' },
  { href: '/servicios/locales-comerciales/',   label: 'Locales Comerciales' },
];
---

<footer>
  <div class="footer-inner">

    <!-- Logo + descripción -->
    <div class="footer-brand">
      <svg width="160" height="30" viewBox="0 0 700 120" xmlns="http://www.w3.org/2000/svg" style="display:block;margin-bottom:14px;">
        <defs>
          <linearGradient id="fg" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#f0d060"/><stop offset="100%" stop-color="#c9a227"/>
          </linearGradient>
          <clipPath id="fL"><rect x="0" y="0" width="60" height="120"/></clipPath>
          <clipPath id="fR"><rect x="60" y="0" width="60" height="120"/></clipPath>
        </defs>
        <rect x="0" y="0" width="60" height="120" fill="#1565a8"/>
        <text x="4" y="90" font-family="'Oswald',sans-serif" font-size="82" font-weight="300" fill="#fff" clip-path="url(#fL)">H</text>
        <line x1="61" y1="16" x2="61" y2="104" stroke="url(#fg)" stroke-width="2.5"/>
        <text x="63" y="90" font-family="'Oswald',sans-serif" font-size="82" font-weight="300" fill="url(#fg)" clip-path="url(#fR)">S</text>
        <line x1="132" y1="14" x2="132" y2="106" stroke="url(#fg)" stroke-width="1.5" opacity=".4"/>
        <text x="150" y="60" font-family="'Bebas Neue',cursive" font-size="52" fill="#fff" letter-spacing="6">PRIVISOR</text>
        <line x1="150" y1="68" x2="688" y2="68" stroke="url(#fg)" stroke-width="1" opacity=".3"/>
        <text x="150" y="84" font-family="'Montserrat',sans-serif" font-size="10" font-weight="700" fill="#c9a227" letter-spacing="2.5">HIGIENE Y SEGURIDAD LABORAL</text>
      </svg>
      <p class="footer-desc">Consultora de Higiene y Seguridad Laboral en CABA y GBA. Profesionales matriculados ante SRT y ART. Cumplimiento normativo integral para empresas.</p>
    </div>

    <!-- Servicios -->
    <div class="footer-col">
      <h3 class="footer-heading">Servicios</h3>
      <ul>
        {servicios.map(s => <li><a href={s.href}>{s.label}</a></li>)}
      </ul>
    </div>

    <!-- Empresa -->
    <div class="footer-col">
      <h3 class="footer-heading">Empresa</h3>
      <ul>
        <li><a href="/nosotros/">Nosotros</a></li>
        <li><a href="/contacto/">Contacto</a></li>
        <li><a href="/blog/">Blog HyS</a></li>
      </ul>
    </div>

    <!-- Contacto / NAP -->
    <div class="footer-col">
      <h3 class="footer-heading">Contacto</h3>
      <!-- NAP (Name, Address, Phone) — crítico para SEO local -->
      <address>
        <p class="nap-item">
          <span class="nap-icon">📍</span>
          Ciudad Autónoma de Buenos Aires y GBA, Argentina
        </p>
        <p class="nap-item">
          <span class="nap-icon">📞</span>
          <a href="tel:+5491133572984">+54 9 11 3357-2984</a>
        </p>
        <p class="nap-item">
          <span class="nap-icon">💬</span>
          <a href="https://wa.me/5491133572984" target="_blank" rel="noopener">WhatsApp</a>
        </p>
      </address>
    </div>

  </div>

  <div class="footer-bottom">
    <p>© {new Date().getFullYear()} Privisor HyS · Todos los derechos reservados</p>
    <p>Profesionales matriculados ante SRT · ISO 45001:2018</p>
  </div>
</footer>

<style>
footer {
  position: relative;
  z-index: 1;
  background: #000d20;
  border-top: 1px solid rgba(100,210,255,0.08);
  padding: 60px 60px 0;
}
.footer-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1.4fr;
  gap: 48px;
  padding-bottom: 48px;
}
.footer-desc {
  font-size: 13px;
  font-weight: 300;
  color: rgba(255,255,255,.35);
  line-height: 1.75;
  max-width: 280px;
}
.footer-heading {
  font-family: 'JetBrains Mono', monospace;
  font-size: .6rem;
  color: rgba(201,162,39,.8);
  letter-spacing: 3px;
  text-transform: uppercase;
  margin-bottom: 16px;
  font-weight: 400;
}
.footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 8px; }
.footer-col a {
  font-size: 13px;
  font-weight: 300;
  color: rgba(255,255,255,.4);
  text-decoration: none;
  transition: color .2s;
}
.footer-col a:hover { color: #64d2ff; }

address { font-style: normal; display: flex; flex-direction: column; gap: 10px; }
.nap-item {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  font-size: 13px;
  font-weight: 300;
  color: rgba(255,255,255,.4);
  line-height: 1.5;
}
.nap-icon { flex-shrink: 0; font-size: .85rem; }
.nap-item a { color: rgba(255,255,255,.4); text-decoration: none; transition: color .2s; }
.nap-item a:hover { color: #64d2ff; }

.footer-bottom {
  max-width: 1200px;
  margin: 0 auto;
  padding: 20px 0;
  border-top: 1px solid rgba(255,255,255,.05);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 8px;
}
.footer-bottom p {
  font-family: 'JetBrains Mono', monospace;
  font-size: .55rem;
  color: rgba(255,255,255,.2);
  letter-spacing: 1px;
}

@media (max-width: 1000px) {
  .footer-inner { grid-template-columns: 1fr 1fr; }
  .footer-brand { grid-column: 1 / -1; }
}
@media (max-width: 600px) {
  footer { padding: 48px 24px 0; }
  .footer-inner { grid-template-columns: 1fr; gap: 32px; }
  .footer-bottom { flex-direction: column; text-align: center; }
}
</style>
