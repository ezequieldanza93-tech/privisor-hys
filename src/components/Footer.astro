---
const servicios = [
  { href: '/servicios/empresas-industriales/', label: 'Empresas Industriales' },
  { href: '/servicios/construccion/',          label: 'Construcción' },
  { href: '/servicios/educativo-recreativo/',  label: 'Educativo & Recreativo' },
  { href: '/servicios/locales-comerciales/',   label: 'Locales Comerciales' },
];
---

<footer>
  <div class="footer-inner">

    <!-- Logo + descripción -->
    <div class="footer-brand">
      <div class="footer-logo">
        <img src="/logo-sigmetria.svg" alt="SIGMETRÍA HyS" width="36" height="36" style="object-fit:contain;flex-shrink:0;" />
        <div class="footer-brand-text">
          <span class="footer-brand-name">SIGMETRÍA</span>
          <span class="footer-brand-sub">HIGIENE Y SEGURIDAD</span>
        </div>
      </div>
      <p class="footer-desc">Consultora de H&amp;S en CABA y provincia de Buenos Aires. Matriculados en COPIME, CPSH y el Colegio de Ingeniería Industrial. Cumplimiento normativo integral para empresas.</p>
    </div>

    <!-- Servicios -->
    <div class="footer-col">
      <h3 class="footer-heading">Servicios</h3>
      <ul>
        {servicios.map(s => <li><a href={s.href}>{s.label}</a></li>)}
      </ul>
    </div>

    <!-- Empresa -->
    <div class="footer-col">
      <h3 class="footer-heading">Empresa</h3>
      <ul>
        <li><a href="/nosotros/">Nosotros</a></li>
        <li><a href="/contacto/">Contacto</a></li>
        <li><a href="/blog/">Blog HyS</a></li>
      </ul>
    </div>

    <!-- Contacto / NAP -->
    <div class="footer-col">
      <h3 class="footer-heading">Contacto</h3>
      <address>
        <p class="nap-item">
          <span class="nap-icon">📍</span>
          CABA y provincia de Buenos Aires, Argentina
        </p>
        <p class="nap-item">
          <span class="nap-icon">📞</span>
          <a href="tel:+5491123496789">+54 9 11 2349-6789</a>
        </p>
        <p class="nap-item">
          <span class="nap-icon">💬</span>
          <a href="https://wa.me/5491123496789" target="_blank" rel="noopener">WhatsApp</a>
        </p>
        <p class="nap-item">
          <span class="nap-icon">✉️</span>
          <a href="mailto:ezequiel@sigmetriahys.com">ezequiel@sigmetriahys.com</a>
        </p>
      </address>
    </div>

  </div>

  <div class="footer-bottom">
    <p>© {new Date().getFullYear()} SIGMETRÍA HyS · Todos los derechos reservados</p>
    <p>Matriculados COPIME · CPSH · Ing. Industrial · ISO 45001:2018</p>
  </div>
</footer>

<style>
footer {
  position: relative;
  z-index: 1;
  background: var(--gris-bg);
  border-top: 1px solid var(--borde);
  padding: 60px 51px 0;
}
.footer-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1.4fr;
  gap: 48px;
  padding-bottom: 48px;
}

/* ---- Logo ---- */
.footer-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 16px;
}
.footer-brand-text {
  display: flex;
  flex-direction: column;
  line-height: 1;
}
.footer-brand-name {
  font-family: 'Montserrat', sans-serif;
  font-size: .9rem;
  font-weight: 800;
  color: var(--gris-1);
  letter-spacing: 1px;
}
.footer-brand-sub {
  font-family: 'Montserrat', sans-serif;
  font-size: .4rem;
  font-weight: 600;
  color: var(--verde);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-top: 3px;
}

.footer-desc {
  font-size: 13px;
  font-weight: 300;
  color: var(--gris-3);
  line-height: 1.75;
  max-width: 280px;
}
.footer-heading {
  font-family: 'Montserrat', sans-serif;
  font-size: .54rem;
  color: var(--verde-dark);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 16px;
  font-weight: 700;
}
.footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 8px; }
.footer-col a {
  font-size: 13px;
  font-weight: 300;
  color: var(--gris-2);
  text-decoration: none;
  transition: color .2s;
}
.footer-col a:hover { color: var(--verde); }

address { font-style: normal; display: flex; flex-direction: column; gap: 10px; }
.nap-item {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  font-size: 13px;
  font-weight: 300;
  color: var(--gris-2);
  line-height: 1.5;
}
.nap-icon { flex-shrink: 0; font-size: .85rem; }
.nap-item a { color: var(--gris-2); text-decoration: none; transition: color .2s; }
.nap-item a:hover { color: var(--verde); }

.footer-bottom {
  max-width: 1200px;
  margin: 0 auto;
  padding: 20px 0;
  border-top: 1px solid var(--borde);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 8px;
}
.footer-bottom p {
  font-family: 'Montserrat', sans-serif;
  font-size: .52rem;
  color: var(--gris-3);
  letter-spacing: .8px;
  text-transform: uppercase;
}

@media (max-width: 1000px) {
  .footer-inner { grid-template-columns: 1fr 1fr; }
  .footer-brand { grid-column: 1 / -1; }
}
@media (max-width: 600px) {
  footer { padding: 48px 24px 0; }
  .footer-inner { grid-template-columns: 1fr; gap: 32px; }
  .footer-bottom { flex-direction: column; text-align: center; }
}
</style>
