---
const currentPath = Astro.url.pathname;

const sectors = [
  {
    label: 'Empresas Industriales',
    href: '/servicios/empresas-industriales/',
    subs: [
      { label: 'Mediciones',        href: '/servicios/empresas-industriales/mediciones/' },
      { label: 'Gestión normativa', href: '/servicios/empresas-industriales/gestion-normativa/' },
      { label: 'ISO 45001',         href: '/servicios/empresas-industriales/iso-45001/' },
    ],
  },
  {
    label: 'Construcción',
    href: '/servicios/construccion/',
    subs: [
      { label: 'Seguridad en obra', href: '/servicios/construccion/seguridad-en-obra/' },
      { label: 'Mediciones',        href: '/servicios/construccion/mediciones/' },
      { label: 'Gestión normativa', href: '/servicios/construccion/gestion-normativa/' },
    ],
  },
  {
    label: 'Educativo & Recreativo',
    href: '/servicios/educativo-recreativo/',
    subs: [
      { label: 'Planes de emergencia', href: '/servicios/educativo-recreativo/planes-de-emergencia/' },
      { label: 'Mediciones',           href: '/servicios/educativo-recreativo/mediciones/' },
      { label: 'Gestión normativa',    href: '/servicios/educativo-recreativo/gestion-normativa/' },
    ],
  },
  {
    label: 'Locales Comerciales',
    href: '/servicios/locales-comerciales/',
    subs: [
      { label: 'Mediciones',           href: '/servicios/locales-comerciales/mediciones/' },
      { label: 'Planes de emergencia', href: '/servicios/locales-comerciales/planes-de-emergencia/' },
      { label: 'Gestión normativa',    href: '/servicios/locales-comerciales/gestion-normativa/' },
    ],
  },
];
---

<nav id="main-nav">
  <a href="/" class="nav-logo" aria-label="SIGMETRÍA HyS — Inicio">
    <svg width="44" height="50" viewBox="0 0 100 112" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" class="nav-triangle">
      <defs>
        <pattern id="navsp" width="5" height="5" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
          <line x1="0" y1="0" x2="0" y2="5" stroke="#A5D6A7" stroke-width="2"/>
        </pattern>
      </defs>
      <polygon points="50,4 4,108 50,108" fill="#4CAF50"/>
      <polygon points="50,4 96,108 50,108" fill="#E8F5E9"/>
      <polygon points="50,4 96,108 50,108" fill="url(#navsp)" opacity=".7"/>
      <line x1="50" y1="4" x2="50" y2="108" stroke="#388E3C" stroke-width="1.5"/>
    </svg>
    <span class="nav-brand">
      <span class="nav-brand-name">SIGMETRÍA</span>
      <span class="nav-brand-sub">HIGIENE Y SEGURIDAD</span>
    </span>
  </a>

  <div class="nav-right">

    <!-- SERVICIOS con flyout dropdown -->
    <div class="nav-item nav-has-dropdown">
      <a
        href="/servicios/"
        class={`nav-link ${currentPath.startsWith('/servicios/') ? 'active' : ''}`}
        aria-haspopup="true"
        aria-expanded="false"
      >
        Servicios <span class="nav-arrow">▾</span>
      </a>

      <!-- Dropdown nivel 1 -->
      <div class="nav-dropdown" role="menu">
        {sectors.map(sector => (
          <div class="nav-subitem">
            <a href={sector.href} class="nav-dropdown-link" role="menuitem">
              {sector.label}
              <span class="nav-sub-arrow">›</span>
            </a>
            <!-- Submenu nivel 2 -->
            <div class="nav-submenu" role="menu">
              <a href={sector.href} class="nav-submenu-header" role="menuitem">
                Ver todo — {sector.label}
              </a>
              <div class="nav-submenu-divider"></div>
              {sector.subs.map(sub => (
                <a href={sub.href} class="nav-submenu-link" role="menuitem">
                  {sub.label}
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <a href="/nosotros/" class={`nav-link ${currentPath === '/nosotros/' ? 'active' : ''}`}>Nosotros</a>

    <!-- BLOG con dropdown de sectores -->
    <div class="nav-item nav-has-dropdown">
      <a
        href="/blog/"
        class={`nav-link ${currentPath.startsWith('/blog/') ? 'active' : ''}`}
        aria-haspopup="true"
        aria-expanded="false"
      >
        Blog H&S <span class="nav-arrow">▾</span>
      </a>
      <div class="nav-dropdown" role="menu">
        <a href="/blog/" class="nav-dropdown-link" role="menuitem">Ver todos los artículos</a>
        <div class="nav-submenu-divider"></div>
        <a href="/blog/?sector=Empresas+Industriales" class="nav-dropdown-link" role="menuitem">Empresas Industriales</a>
        <a href="/blog/?sector=Construcci%C3%B3n" class="nav-dropdown-link" role="menuitem">Construcción</a>
        <a href="/blog/?sector=Educativo+y+Recreativo" class="nav-dropdown-link" role="menuitem">Educativo &amp; Recreativo</a>
        <a href="/blog/?sector=Comercial+y+Oficinas" class="nav-dropdown-link" role="menuitem">Locales Comerciales</a>
      </div>
    </div>

    <a href="/contacto/"  class={`nav-link ${currentPath === '/contacto/'  ? 'active' : ''}`}>Contacto</a>
    <a href="/contacto/" class="nav-cta">Consultanos</a>
  </div>

  <button class="nav-hamburger" id="nav-toggle" aria-label="Abrir menú" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>
</nav>

<!-- Mobile menu -->
<div class="nav-mobile" id="nav-mobile" role="navigation" aria-label="Menú mobile">
  <div class="nav-mobile-item">
    <button class="nav-mobile-toggle" id="mobile-servicios-toggle" aria-expanded="false">
      Servicios <span class="mobile-arrow">▾</span>
    </button>
    <div class="nav-mobile-sub" id="mobile-servicios-sub">
      {sectors.map(sector => (
        <div class="nav-mobile-sector">
          <button class={`nav-mobile-sector-toggle`} aria-expanded="false">
            {sector.label} <span class="mobile-arrow">›</span>
          </button>
          <div class="nav-mobile-sector-links">
            <a href={sector.href} class="nav-mobile-link">Ver todo</a>
            {sector.subs.map(sub => (
              <a href={sub.href} class="nav-mobile-link">{sub.label}</a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
  <a href="/nosotros/" class="nav-mobile-link nav-mobile-root">Nosotros</a>
  <div class="nav-mobile-item">
    <button class="nav-mobile-toggle" id="mobile-blog-toggle" aria-expanded="false">
      Blog H&S <span class="mobile-arrow">▾</span>
    </button>
    <div class="nav-mobile-sub" id="mobile-blog-sub">
      <a href="/blog/" class="nav-mobile-link">Ver todos los artículos</a>
      <a href="/blog/?sector=Empresas+Industriales" class="nav-mobile-link">Empresas Industriales</a>
      <a href="/blog/?sector=Construcci%C3%B3n" class="nav-mobile-link">Construcción</a>
      <a href="/blog/?sector=Educativo+y+Recreativo" class="nav-mobile-link">Educativo &amp; Recreativo</a>
      <a href="/blog/?sector=Comercial+y+Oficinas" class="nav-mobile-link">Locales Comerciales</a>
    </div>
  </div>
  <a href="/contacto/"  class="nav-mobile-link nav-mobile-root">Contacto</a>
  <a href="/contacto/" class="btn-primary" style="margin-top:8px;">Consultanos</a>
</div>

<style>
/* ---- NAV BASE ---- */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 200;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 51px;
  height: 68px;
  background: rgba(255,255,255,.97);
  border-bottom: 1px solid var(--borde);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  transition: box-shadow .3s ease;
}
nav.scrolled {
  box-shadow: 0 2px 20px rgba(0,0,0,.08);
}

/* ---- LOGO ---- */
.nav-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
}
.nav-triangle {
  flex-shrink: 0;
  display: block;
}
.nav-brand {
  display: flex;
  flex-direction: column;
  line-height: 1;
}
.nav-brand-name {
  font-family: 'Montserrat', sans-serif;
  font-size: .95rem;
  font-weight: 800;
  color: var(--gris-1);
  letter-spacing: 1px;
}
.nav-brand-sub {
  font-family: 'Montserrat', sans-serif;
  font-size: .42rem;
  font-weight: 600;
  color: var(--verde);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-top: 3px;
}

.nav-right { display: flex; align-items: center; gap: 2px; }

/* ---- LINKS ---- */
.nav-link {
  font-family: 'Montserrat', sans-serif;
  font-size: .72rem;
  font-weight: 600;
  color: var(--gris-2);
  text-decoration: none;
  letter-spacing: .6px;
  text-transform: uppercase;
  transition: color .2s;
  padding: 8px 12px;
  border-radius: 4px;
  display: flex;
  align-items: center;
  gap: 5px;
  white-space: nowrap;
}
.nav-link:hover, .nav-link.active { color: var(--verde); }
.nav-arrow { font-size: .6rem; opacity: .7; transition: transform .2s; }

.nav-cta {
  background: var(--verde);
  color: #fff;
  padding: 9px 22px;
  border-radius: 4px;
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: .72rem;
  letter-spacing: .8px;
  text-transform: uppercase;
  text-decoration: none;
  transition: all .2s;
  margin-left: 8px;
}
.nav-cta:hover { background: var(--verde-dark); }

/* ---- DROPDOWN NIVEL 1 ---- */
.nav-item { position: relative; }

.nav-dropdown {
  position: absolute;
  top: 100%;
  left: 0;
  min-width: 220px;
  background: #fff;
  border: 1px solid var(--borde);
  border-radius: 8px;
  padding: 8px 0;
  box-shadow: 0 12px 40px rgba(0,0,0,.1);
  opacity: 0;
  pointer-events: none;
  transform: translateY(-4px);
  transition: opacity .18s ease, transform .18s ease;
  z-index: 300;
}

.nav-has-dropdown:hover .nav-dropdown,
.nav-has-dropdown:focus-within .nav-dropdown {
  opacity: 1;
  pointer-events: all;
  transform: translateY(0);
}
.nav-has-dropdown:hover .nav-arrow { transform: rotate(180deg); }

/* ---- ITEMS NIVEL 1 ---- */
.nav-subitem { position: relative; }

.nav-dropdown-link {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 9px 16px;
  font-family: 'Montserrat', sans-serif;
  font-size: .75rem;
  font-weight: 500;
  color: var(--gris-2);
  text-decoration: none;
  letter-spacing: .3px;
  transition: all .15s;
  white-space: nowrap;
  gap: 8px;
}
.nav-dropdown-link:hover { color: var(--verde); background: var(--verde-light); }
.nav-sub-arrow {
  font-size: .9rem;
  color: var(--verde);
  opacity: .5;
  flex-shrink: 0;
  transition: transform .15s;
}
.nav-subitem:hover .nav-sub-arrow { transform: translateX(3px); opacity: 1; }

/* ---- SUBMENU NIVEL 2 ---- */
.nav-submenu {
  position: absolute;
  top: -6px;
  left: calc(100% + 2px);
  min-width: 210px;
  background: #fff;
  border: 1px solid var(--borde);
  border-radius: 8px;
  padding: 6px 0;
  box-shadow: 8px 12px 40px rgba(0,0,0,.1);
  opacity: 0;
  pointer-events: none;
  transform: translateX(-6px);
  transition: opacity .15s ease, transform .15s ease;
  z-index: 310;
}
.nav-subitem:hover .nav-submenu,
.nav-subitem:focus-within .nav-submenu {
  opacity: 1;
  pointer-events: all;
  transform: translateX(0);
}
.nav-subitem:hover .nav-dropdown-link { color: var(--verde); background: var(--verde-light); }

.nav-submenu-header {
  display: block;
  padding: 8px 16px;
  font-family: 'Montserrat', sans-serif;
  font-size: .54rem;
  color: var(--verde-dark);
  letter-spacing: 1px;
  text-decoration: none;
  text-transform: uppercase;
  font-weight: 700;
  transition: color .15s;
}
.nav-submenu-header:hover { color: var(--verde); }

.nav-submenu-divider {
  height: 1px;
  background: var(--borde);
  margin: 4px 10px;
}

.nav-submenu-link {
  display: block;
  padding: 8px 16px;
  font-family: 'Montserrat', sans-serif;
  font-size: .73rem;
  font-weight: 400;
  color: var(--gris-2);
  text-decoration: none;
  letter-spacing: .2px;
  transition: all .15s;
  white-space: nowrap;
}
.nav-submenu-link:hover { color: var(--verde); background: var(--verde-light); padding-left: 20px; }

/* ---- HAMBURGER ---- */
.nav-hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 4px;
}
.nav-hamburger span { width: 24px; height: 2px; background: var(--gris-2); border-radius: 2px; transition: all .2s; }
.nav-hamburger.open span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
.nav-hamburger.open span:nth-child(2) { opacity: 0; }
.nav-hamburger.open span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

/* ---- MOBILE MENU ---- */
.nav-mobile {
  position: fixed;
  top: 68px; left: 0; right: 0;
  z-index: 199;
  background: #fff;
  border-bottom: 1px solid var(--borde);
  padding: 12px 24px 24px;
  display: flex;
  flex-direction: column;
  gap: 2px;
  transform: translateY(-200%);
  transition: transform .3s ease;
  max-height: calc(100vh - 68px);
  overflow-y: auto;
  box-shadow: 0 8px 24px rgba(0,0,0,.08);
}
.nav-mobile.open { transform: translateY(0); }

.nav-mobile-toggle, .nav-mobile-sector-toggle {
  width: 100%;
  background: transparent;
  border: none;
  color: var(--gris-1);
  font-family: 'Montserrat', sans-serif;
  font-size: .82rem;
  font-weight: 600;
  letter-spacing: .6px;
  text-transform: uppercase;
  padding: 12px 0;
  text-align: left;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid var(--borde);
}
.nav-mobile-sector-toggle { font-size: .75rem; padding: 9px 12px; color: var(--gris-2); border-bottom: none; }
.mobile-arrow { transition: transform .2s; font-size: .7rem; color: var(--verde); }
.nav-mobile-toggle.open .mobile-arrow,
.nav-mobile-sector-toggle.open .mobile-arrow { transform: rotate(90deg); }

.nav-mobile-sub { display: none; padding-left: 8px; }
.nav-mobile-sub.open { display: block; }
.nav-mobile-sector { border-left: 2px solid var(--verde-borde); margin: 2px 0; padding-left: 4px; }
.nav-mobile-sector-links { display: none; padding-left: 12px; }
.nav-mobile-sector-links.open { display: flex; flex-direction: column; }

.nav-mobile-link {
  font-family: 'Montserrat', sans-serif;
  font-size: .78rem;
  font-weight: 400;
  color: var(--gris-2);
  text-decoration: none;
  padding: 8px 0 8px 4px;
  display: block;
  transition: color .2s;
  border-bottom: 1px solid var(--borde);
}
.nav-mobile-link:hover { color: var(--verde); }
.nav-mobile-root {
  font-weight: 600;
  font-size: .82rem;
  color: var(--gris-1);
  text-transform: uppercase;
  letter-spacing: .6px;
  padding: 12px 0;
  border-bottom: 1px solid var(--borde);
}

@media (max-width: 900px) {
  nav { padding: 0 24px; }
  .nav-right { display: none; }
  .nav-hamburger { display: flex; }
}
</style>

<script>
window.addEventListener('scroll', () => {
  document.getElementById('main-nav')?.classList.toggle('scrolled', window.scrollY > 60);
});

const toggle = document.getElementById('nav-toggle');
const mobileMenu = document.getElementById('nav-mobile');
toggle?.addEventListener('click', () => {
  const isOpen = mobileMenu?.classList.toggle('open');
  toggle.classList.toggle('open', isOpen);
  toggle.setAttribute('aria-expanded', String(isOpen));
});

const serviciosToggle = document.getElementById('mobile-servicios-toggle');
const serviciosSub = document.getElementById('mobile-servicios-sub');
serviciosToggle?.addEventListener('click', () => {
  const isOpen = serviciosSub?.classList.toggle('open');
  serviciosToggle.classList.toggle('open', isOpen);
  serviciosToggle.setAttribute('aria-expanded', String(isOpen));
});

const blogToggle = document.getElementById('mobile-blog-toggle');
const blogSub = document.getElementById('mobile-blog-sub');
blogToggle?.addEventListener('click', () => {
  const isOpen = blogSub?.classList.toggle('open');
  blogToggle.classList.toggle('open', isOpen);
  blogToggle.setAttribute('aria-expanded', String(isOpen));
});

document.querySelectorAll('.nav-mobile-sector-toggle').forEach(btn => {
  btn.addEventListener('click', () => {
    const links = btn.nextElementSibling as HTMLElement;
    const isOpen = links?.classList.toggle('open');
    btn.classList.toggle('open', isOpen);
    btn.setAttribute('aria-expanded', String(isOpen));
  });
});

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    mobileMenu?.classList.remove('open');
    toggle?.classList.remove('open');
    toggle?.setAttribute('aria-expanded', 'false');
  }
});
</script>
